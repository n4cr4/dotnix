{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "tokyonight",
  "keybinds": {
    "app_exit": "ctrl+q",
    "variant_cycle": "none",
    "input_submit": "ctrl+return",
    "input_newline": "return",
    "input_delete_to_line_start": "ctrl+k",
    "input_line_home": "home",
    "input_line_end": "end",
    "input_buffer_home": "pageup",
    "input_buffer_end": "pagedown",
    "messages_page_up": "ctrl+u",
    "messages_page_down": "ctrl+d"
  }
}
